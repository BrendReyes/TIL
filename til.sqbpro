FROM entries
WHERE last_reviewed_at IS NULL
   OR datetime(last_reviewed_at, '+' || review_interval_days || ' days') &lt;= datetime('now')
ORDER BY last_reviewed_at ASC NULLS FIRST;</sql><sql name="SQL 1* (1)">
-- 1. Overdue: Reviewed 2 days ago with a 1-day interval (Should appear)
INSERT INTO entries (body, tag, created_at, updated_at, last_reviewed_at, review_interval_days, review_count, ease_factor)
VALUES (
    'This is an overdue entry (2 days ago, 1 day interval)',
    'testing',
    datetime('now', '-10 days'),
    datetime('now', '-2 days'),
    datetime('now', '-2 days'),
    1,
    1,
    2.5
);

-- 2. Overdue: Long-term memory test (Reviewed 15 days ago, 7-day interval) (Should appear)
INSERT INTO entries (body, tag, created_at, updated_at, last_reviewed_at, review_interval_days, review_count, ease_factor)
VALUES (
    'Complex entry with high ease factor',
    'go',
    datetime('now', '-30 days'),
    datetime('now', '-15 days'),
    datetime('now', '-15 days'),
    7,
    3,
    2.8
);

-- 3. Due Today: Reviewed exactly 1 day ago with 1-day interval (Should appear)
INSERT INTO entries (body, tag, created_at, updated_at, last_reviewed_at, review_interval_days, review_count, ease_factor)
VALUES (
    'Entry due right now',
    'sql',
    datetime('now', '-5 days'),
    datetime('now', '-1 day'),
    datetime('now', '-1 day'),
    1,
    2,
    2.1
);

-- 4. NOT Due: Reviewed 1 hour ago with 1-day interval (Should NOT appear)
INSERT INTO entries (body, tag, created_at, updated_at, last_reviewed_at, review_interval_days, review_count, ease_factor)
VALUES (
    'Freshly reviewed entry (Not due yet)',
    'hidden',
    datetime('now', '-1 day'),
    datetime('now', '-1 hour'),
    datetime('now', '-1 hour'),
    1,
    1,
    2.5
);

-- 5. NOT Due: High interval (Reviewed 2 days ago, 30-day interval) (Should NOT appear)
INSERT INTO entries (body, tag, created_at, updated_at, last_reviewed_at, review_interval_days, review_count, ease_factor)
VALUES (
    'Mastered entry with long interval',
    'docker',
    datetime('now', '-60 days'),
    datetime('now', '-2 days'),
    datetime('now', '-2 days'),
    30,
    10,
    3.0
);
</sql><current_tab id="0"/></tab_sql></sqlb_project>
